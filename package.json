{
  "name": "@eddiearc/skilltap",
  "version": "1.0.0",
  "description": "Install AI agent skills from any git repository. One repo = one skill tap.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "skilltap": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "ai",
    "agent",
    "skills",
    "github",
    "marketplace",
    "claude",
    "codex",
    "SKILL.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/eddiearc/skilltap"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "eslint": "^9.25.0"
  }
}
